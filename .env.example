# ─── SERVEUR ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── BASE DE DONNÉES ──────────────────────────────────────
# Remplace par ton URI MongoDB Atlas
MONGO_URI=mongodb+srv://<utilisateur>:<motdepasse>@cluster0.xxxxx.mongodb.net/freelancehub

# ─── JWT ──────────────────────────────────────────────────
# Génère une clé secrète longue et aléatoire (ex: openssl rand -base64 32)
JWT_SECRET=ta_cle_secrete_tres_longue_et_aleatoire_ici
JWT_EXPIRES_IN=7d

# ─── WAVE API ─────────────────────────────────────────────
WAVE_API_KEY=
WAVE_BASE_URL=https://api.wave.com/v1

# ─── ORANGE MONEY API ─────────────────────────────────────
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1
